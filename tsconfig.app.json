{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": false,

    /* Strictness — ligamos null checks e mantemos pragmatismo no resto.
       Não ativamos `strict: true` inteiro para evitar quebrar muito código
       herdado do gerador do Lovable de uma vez. Vá apertando aos poucos. */
    "strict": false,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    "paths": {
      "@/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "target": "ES2020",
    "types": ["vitest/globals"],
    "useDefineForClassFields": true
  },
  "include": ["src"]
}
